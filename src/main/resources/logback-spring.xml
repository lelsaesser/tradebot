<?xml version="1.0" encoding="UTF-8"?>
<!--
  Spring Boot's default Logback configuration plus a global secret-redaction TurboFilter.

  The <include> directives keep Spring Boot's auto-configured console appender, color encoding,
  conversion rules, and base log levels intact - we only add the SecretRedactingTurboFilter on
  top. See https://docs.spring.io/spring-boot/reference/features/logging.html#features.logging.logback-extensions
-->
<configuration>
    <include resource="org/springframework/boot/logging/logback/defaults.xml"/>
    <include resource="org/springframework/boot/logging/logback/console-appender.xml"/>

    <turboFilter class="org.tradelite.logging.SecretRedactingTurboFilter"/>

    <root level="INFO">
        <appender-ref ref="CONSOLE"/>
    </root>
</configuration>
